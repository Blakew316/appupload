# Copy to .env and fill in. Required for live transcription.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Model used for handwriting transcription.
# Default is claude-sonnet-4-6 (great accuracy/cost balance).
# For the hardest handwriting, use claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional. Port the server listens on (default 3000).
PORT=3000

# Optional. Set to 1 to run a demo without an API key:
# uploads return a sample transcription so you can preview the workflow.
# TRANSCRIBE_MOCK=1
